{
    "name": "dynasense",
    "displayName": "DynaSense",
    "description": "Smart LS-DYNA Editor with Syntax Highlighting, Formatting, and Advanced IntelliSense",
    "publisher": "hqyyqh",
    "author": "hqyyqh",
    "license": "SEE LICENSE IN LICENSE",
    "private": true,
    "repository": {
        "type": "git",
        "url": "https://github.com/hqyyqh/vscode-lsdyna"
    },
    "icon": "images/extension-icon.png",
    "version": "3.0.11",
    "engines": {
        "vscode": "^1.50.0"
    },
    "activationEvents": [
        "onLanguage:lsdyna",
        "onLanguage:lsprepost-command-file",
        "onCommand:extension.openIncludeFile",
        "onCommand:extension.selectKeyword",
        "onCommand:extension.lsdynaShiftTab",
        "onCommand:extension.lsdynaSelectCell",
        "onCommand:extension.lsdynaFormatSelection",
        "onCommand:extension.jumpToNextKeyword",
        "onCommand:extension.jumpToPreviousKeyword",
        "onCommand:extension.scanIncludeTree",
        "onCommand:extension.scanKeywordIndex",
        "onCommand:extension.keywordIndexSetLocal",
        "onCommand:extension.openToSide",
        "onCommand:extension.revealInExplorer",
        "onCommand:extension.openManual",
        "onCommand:extension.openLsdynaReferenceDefinition",
        "onCommand:extension.lsdynaChooseKeywordOptions",
        "onCommand:extension.configureManualsDir",
        "onCommand:extension.lsdynaTab"
    ],
    "main": "./out/extension.js",
    "categories": [
        "Programming Languages"
    ],
    "scripts": {
        "compile": "tsc -p .",
        "check:contracts": "node scripts/validate-project-contracts.cjs",
        "watch": "tsc -watch -p .",
        "test": "npm run compile && mocha --require test/register-out.js test/**/*.test.js",
        "test:scanner-benchmark": "npm run compile && mocha --require test/register-out.js test/core/scanner/scannerBenchmark.test.js",
        "package": "npm run compile && vsce package",
        "vscode:prepublish": "npm run compile"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.10",
        "@types/node": "^22.0.0",
        "@types/vscode": "^1.50.0",
        "@vscode/vsce": "^3.9.2",
        "mocha": "^10.0.0",
        "ovsx": "^1.0.1",
        "typescript": "^6.0.3"
    },
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "lsdyna-includes",
                    "title": "%viewsContainers.lsdyna-includes.title%",
                    "icon": "images/activitybar-icon.svg"
                }
            ]
        },
        "views": {
            "lsdyna-includes": [
                {
                    "id": "lsdynaIncludeTree",
                    "name": "%views.lsdynaIncludeTree.name%"
                },
                {
                    "id": "lsdynaKeywordIndex",
                    "name": "%views.lsdynaKeywordIndex.name%"
                }
            ]
        },
        "viewsWelcome": [
            {
                "view": "lsdynaIncludeTree",
                "contents": "%viewsWelcome.lsdynaIncludeTree.contents%"
            },
            {
                "view": "lsdynaKeywordIndex",
                "contents": "%viewsWelcome.lsdynaKeywordIndex.contents%"
            }
        ],
        "configurationDefaults": {
            "[lsdyna]": {
                "editor.quickSuggestions": {
                    "other": false,
                    "comments": false,
                    "strings": false
                },
                "editor.suggest.showWords": false,
                "editor.wordBasedSuggestions": "off",
                "editor.wordSeparators": "`~!@#$%^&*()=+[{]}\\|;:'\",<>/?",
                "editor.wordWrap": "off",
                "editor.guides.indentation": false,
                "editor.renderIndentGuides": false,
                "editor.renderWhitespace": "all",
                "editor.insertSpaces": true,
                "editor.detectIndentation": false,
                "editor.rulers": [
                    {
                        "column": 10,
                        "color": "rgba(128, 128, 128, 0.15)"
                    },
                    {
                        "column": 20,
                        "color": "rgba(128, 128, 128, 0.15)"
                    },
                    {
                        "column": 30,
                        "color": "rgba(128, 128, 128, 0.15)"
                    },
                    {
                        "column": 40,
                        "color": "rgba(128, 128, 128, 0.15)"
                    },
                    {
                        "column": 50,
                        "color": "rgba(128, 128, 128, 0.15)"
                    },
                    {
                        "column": 60,
                        "color": "rgba(128, 128, 128, 0.15)"
                    },
                    {
                        "column": 70,
                        "color": "rgba(128, 128, 128, 0.15)"
                    },
                    {
                        "column": 80,
                        "color": "#8a5cf5"
                    }
                ]
            }
        },
        "languages": [
            {
                "id": "lsdyna",
                "aliases": [
                    "LS-Dyna",
                    "lsdyna"
                ],
                "extensions": [
                    ".k",
                    ".key",
                    ".dyna",
                    ".asc"
                ],
                "icon": {
                    "light": "./images/ls.svg",
                    "dark": "./images/ls.svg"
                },
                "configuration": "./language-configuration.json"
            },
            {
                "id": "lsprepost-command-file",
                "aliases": [
                    "LS-PrePost Command File"
                ],
                "extensions": [
                    ".cfile"
                ],
                "configuration": "./language-configuration-lspp-cfile.json"
            }
        ],
        "grammars": [
            {
                "language": "lsdyna",
                "scopeName": "source.lsdyna",
                "path": "./syntaxes/lsdyna.tmLanguage.json"
            },
            {
                "language": "lsprepost-command-file",
                "scopeName": "source.lsprepost-command-file",
                "path": "./syntaxes/lspp-cfile.tmLanguage.json"
            }
        ],
        "commands": [
            {
                "command": "extension.openIncludeFile",
                "title": "%commands.openIncludeFile.title%"
            },
            {
                "command": "extension.selectKeyword",
                "title": "%commands.selectKeyword.title%"
            },
            {
                "command": "extension.lsdynaShiftTab",
                "title": "%commands.lsdynaShiftTab.title%"
            },
            {
                "command": "extension.lsdynaSelectCell",
                "title": "%commands.lsdynaSelectCell.title%"
            },
            {
                "command": "extension.lsdynaFormatSelection",
                "title": "%commands.lsdynaFormatSelection.title%"
            },
            {
                "command": "extension.jumpToNextKeyword",
                "title": "%commands.jumpToNextKeyword.title%",
                "icon": "$(arrow-down)"
            },
            {
                "command": "extension.jumpToPreviousKeyword",
                "title": "%commands.jumpToPreviousKeyword.title%",
                "icon": "$(arrow-up)"
            },
            {
                "command": "extension.scanIncludeTree",
                "title": "%commands.scanIncludeTree.title%",
                "icon": "$(refresh)"
            },
            {
                "command": "extension.scanKeywordIndex",
                "title": "%commands.scanKeywordIndex.title%",
                "icon": "$(list-tree)"
            },
            {
                "command": "extension.keywordIndexSetLocal",
                "title": "%commands.keywordIndexSetLocal.title%",
                "icon": "$(file-text)"
            },
            {
                "command": "extension.openToSide",
                "title": "%commands.openToSide.title%",
                "icon": "$(split-horizontal)"
            },
            {
                "command": "extension.revealInExplorer",
                "title": "%commands.revealInExplorer.title%",
                "icon": "$(folder-opened)"
            },
            {
                "command": "extension.openManual",
                "title": "%commands.openManual.title%",
                "category": "LS-DYNA"
            },
            {
                "command": "extension.openLsdynaReferenceDefinition",
                "title": "%commands.openLsdynaReferenceDefinition.title%",
                "icon": "$(go-to-file)"
            },
            {
                "command": "extension.lsdynaChooseKeywordOptions",
                "title": "%commands.lsdynaChooseKeywordOptions.title%",
                "category": "LS-DYNA"
            },
            {
                "command": "extension.configureManualsDir",
                "title": "%commands.configureManualsDir.title%",
                "category": "LS-DYNA"
            },
            {
                "command": "extension.lsdynaTab",
                "title": "%commands.lsdynaTab.title%"
            }
        ],
        "keybindings": [
            {
                "command": "extension.jumpToNextKeyword",
                "key": "ctrl+alt+down",
                "when": "editorLangId == 'lsdyna'"
            },
            {
                "command": "extension.jumpToPreviousKeyword",
                "key": "ctrl+alt+up",
                "when": "editorLangId == 'lsdyna'"
            },
            {
                "command": "extension.lsdynaTab",
                "key": "tab",
                "when": "editorTextFocus && editorLangId == 'lsdyna' && !suggestWidgetVisible && lsdyna.shouldAlignTab && config.lsdyna.enableTabNavigation"
            },
            {
                "command": "extension.lsdynaShiftTab",
                "key": "shift+tab",
                "when": "editorTextFocus && editorLangId == 'lsdyna' && !suggestWidgetVisible && lsdyna.shouldAlignTab && config.lsdyna.enableTabNavigation"
            },
            {
                "command": "extension.lsdynaSelectCell",
                "key": "shift+alt+right",
                "when": "editorTextFocus && editorLangId == 'lsdyna' && lsdyna.shouldAlignTab && config.lsdyna.enableTabNavigation"
            }
        ],
        "configuration": {
            "title": "LS-DYNA",
            "properties": {
                "lsdyna.manualsDir": {
                    "type": "string",
                    "default": "lsdyna_manual_pack",
                    "description": "%config.manualsDir.description%"
                },
                "lsdyna.enableTabNavigation": {
                    "type": "boolean",
                    "default": true,
                    "description": "%config.enableTabNavigation.description%"
                },
                "lsdyna.largeFile.enableRendering": {
                    "type": "boolean",
                    "default": true,
                    "description": "%config.largeFile.enableRendering.description%"
                },
                "lsdyna.codeLens.showOnAllKeywords": {
                    "type": "boolean",
                    "default": false,
                    "description": "%config.codeLens.showOnAllKeywords.description%"
                },
                "lsdyna.hover.previewMaxLines": {
                    "type": "number",
                    "default": 20,
                    "minimum": 0,
                    "maximum": 500,
                    "description": "%config.hover.previewMaxLines.description%"
                },
                "lsdyna.autoFormat": {
                    "type": "string",
                    "enum": [
                        "onBlur",
                        "disabled"
                    ],
                    "default": "disabled",
                    "enumDescriptions": [
                        "%config.autoFormat.enumDescriptions.onBlur%",
                        "%config.autoFormat.enumDescriptions.disabled%"
                    ],
                    "tags": [
                        "experimental"
                    ],
                    "description": "%config.autoFormat.description%"
                },
                "lsdyna.language": {
                    "type": "string",
                    "enum": [
                        "auto",
                        "zh-cn",
                        "en"
                    ],
                    "default": "auto",
                    "enumDescriptions": [
                        "%config.language.enumDescriptions.auto%",
                        "%config.language.enumDescriptions.zh-cn%",
                        "%config.language.enumDescriptions.en%"
                    ],
                    "description": "%config.language.description%"
                },
                "lsdyna.additionalExtensions": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [
                        ".k",
                        ".key",
                        ".dyna",
                        ".asc"
                    ],
                    "description": "%config.additionalExtensions.description%"
                },
                "lsdyna.scanner.fullScanLargeFiles": {
                    "type": "boolean",
                    "default": false,
                    "markdownDescription": "%config.scanner.fullScanLargeFiles.markdownDescription%"
                },
                "lsdyna.ignoreFormattingKeywords": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [],
                    "description": "%config.ignoreFormattingKeywords.description%"
                },
                "lsdyna.customValidKeywords": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [
                        "*END",
                        "*TITLE",
                        "*CASE_BEGIN",
                        "*CASE_END"
                    ],
                    "description": "%config.customValidKeywords.description%"
                }
            }
        },
        "menus": {
            "view/title": [
                {
                    "command": "extension.scanIncludeTree",
                    "when": "view == lsdynaIncludeTree",
                    "group": "navigation"
                },
                {
                    "command": "extension.scanKeywordIndex",
                    "when": "view == lsdynaKeywordIndex && lsdyna.keywordIndexMode == 'local'",
                    "group": "navigation"
                },
                {
                    "command": "extension.keywordIndexSetLocal",
                    "when": "view == lsdynaKeywordIndex && lsdyna.keywordIndexMode == 'recursive'",
                    "group": "navigation"
                }
            ],
            "editor/context": [
                {
                    "command": "extension.lsdynaFormatSelection",
                    "when": "editorLangId == 'lsdyna'",
                    "group": "lsdyna@1"
                },
                {
                    "command": "extension.selectKeyword",
                    "when": "editorLangId == 'lsdyna'",
                    "group": "lsdyna@2"
                },
                {
                    "command": "extension.lsdynaChooseKeywordOptions",
                    "when": "editorLangId == 'lsdyna'",
                    "group": "lsdyna@3"
                },
                {
                    "command": "extension.openIncludeFile",
                    "when": "editorLangId == 'lsdyna' && lsdyna.onIncludeLine",
                    "group": "lsdyna@4"
                }
            ],
            "editor/title": [
                {
                    "command": "extension.jumpToNextKeyword",
                    "when": "editorLangId == 'lsdyna'",
                    "group": "navigation"
                },
                {
                    "command": "extension.jumpToPreviousKeyword",
                    "when": "editorLangId == 'lsdyna'",
                    "group": "navigation"
                }
            ],
            "view/item/context": [
                {
                    "command": "extension.openToSide",
                    "when": "view == lsdynaIncludeTree && viewItem == file || view == lsdynaKeywordIndex && viewItem == file",
                    "group": "inline"
                },
                {
                    "command": "extension.revealInExplorer",
                    "when": "view == lsdynaIncludeTree && viewItem == file || view == lsdynaKeywordIndex && viewItem == file",
                    "group": "inline"
                }
            ]
        }
    },
    "dependencies": {
        "vscode-languageclient": "^7.0.0",
        "vscode-languageserver": "^7.0.0"
    }
}
