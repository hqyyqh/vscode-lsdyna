{
    "name": "lsdyna-custom",
    "displayName": "LS-DYNA (Customized by hqyyqh)",
    "description": "Syntax Highlighting and Snippets for LS-Dyna Deck Creation and Editing",
    "publisher": "hqyyqh",
    "author": "hqyyqh",
    "license": "SEE LICENSE IN LICENSE",
    "private": true,
    "repository": {
        "type": "git",
        "url": "https://github.com/hqyyqh/vscode-lsdyna"
    },
    "icon": "images/LS_DYNA_geo_metro.png",
    "version": "2.0.7-hqyyqh.4",
    "engines": {
        "vscode": "^1.50.0"
    },
    "activationEvents": [
        "onLanguage:lsdyna",
        "onLanguage:lsprepost-command-file",
        "onCommand:extension.openManual"
    ],
    "main": "./src/extension.js",
    "categories": [
        "Programming Languages"
    ],
    "scripts": {
        "test": "mocha test/**/*.test.js",
        "package": "vsce package"
    },
    "devDependencies": {
        "mocha": "^10.0.0"
    },
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "lsdyna-includes",
                    "title": "%viewsContainers.lsdyna-includes.title%",
                    "icon": "images/lsdyna.png"
                }
            ]
        },
        "views": {
            "lsdyna-includes": [
                {
                    "id": "lsdynaIncludeTree",
                    "name": "%views.lsdynaIncludeTree.name%"
                },
                {
                    "id": "lsdynaKeywordIndex",
                    "name": "%views.lsdynaKeywordIndex.name%"
                }
            ]
        },
        "viewsWelcome": [
            {
                "view": "lsdynaIncludeTree",
                "contents": "%viewsWelcome.lsdynaIncludeTree.contents%"
            },
            {
                "view": "lsdynaKeywordIndex",
                "contents": "%viewsWelcome.lsdynaKeywordIndex.contents%"
            }
        ],
        "configurationDefaults": {
            "[lsdyna]": {
                "editor.autoIndent": "none"
            }
        },
        "languages": [
            {
                "id": "lsdyna",
                "aliases": [
                    "LS-Dyna",
                    "lsdyna"
                ],
                "extensions": [
                    ".k",
                    ".key",
                    ".dyna"
                ],
                "configuration": "./language-configuration.json"
            },
            {
                "id": "lsprepost-command-file",
                "aliases": [
                    "LS-PrePost Command File"
                ],
                "extensions": [
                    ".cfile"
                ],
                "configuration": "./language-configuration-lspp-cfile.json"
            }
        ],
        "grammars": [
            {
                "language": "lsdyna",
                "scopeName": "source.lsdyna",
                "path": "./syntaxes/lsdyna.tmLanguage.json"
            },
            {
                "language": "lsprepost-command-file",
                "scopeName": "source.lsprepost-command-file",
                "path": "./syntaxes/lspp-cfile.tmLanguage.json"
            }
        ],

        "commands": [
            {
                "command": "extension.openIncludeFile",
                "title": "%commands.openIncludeFile.title%"
            },
            {
                "command": "extension.selectKeyword",
                "title": "%commands.selectKeyword.title%"
            },
            {
                "command": "extension.lsdynaShiftTab",
                "title": "%commands.lsdynaShiftTab.title%"
            },
            {
                "command": "extension.lsdynaSelectCell",
                "title": "%commands.lsdynaSelectCell.title%"
            },
            {
                "command": "extension.lsdynaFormatSelection",
                "title": "%commands.lsdynaFormatSelection.title%"
            },
            {
                "command": "extension.jumpToNextKeyword",
                "title": "%commands.jumpToNextKeyword.title%",
                "icon": "$(arrow-down)"
            },
            {
                "command": "extension.jumpToPreviousKeyword",
                "title": "%commands.jumpToPreviousKeyword.title%",
                "icon": "$(arrow-up)"
            },
            {
                "command": "extension.scanIncludeTree",
                "title": "%commands.scanIncludeTree.title%",
                "icon": "$(refresh)"
            },
            {
                "command": "extension.scanKeywordIndex",
                "title": "%commands.scanKeywordIndex.title%",
                "icon": "$(list-tree)"
            },
            {
                "command": "extension.keywordIndexSetLocal",
                "title": "%commands.keywordIndexSetLocal.title%",
                "icon": "$(file-text)"
            },
            {
                "command": "extension.openToSide",
                "title": "%commands.openToSide.title%",
                "icon": "$(split-horizontal)"
            },
            {
                "command": "extension.revealInExplorer",
                "title": "%commands.revealInExplorer.title%",
                "icon": "$(folder-opened)"
            },
            {
                "command": "extension.openManual",
                "title": "%commands.openManual.title%",
                "category": "LS-DYNA"
            },
            {
                "command": "extension.configureManualsDir",
                "title": "%commands.configureManualsDir.title%",
                "category": "LS-DYNA"
            },
            {
                "command": "extension.lsdynaTab",
                "title": "%commands.lsdynaTab.title%"
            }
        ],

        "keybindings": [
            {
                "command": "extension.jumpToNextKeyword",
                "key": "ctrl+alt+down",
                "when": "editorLangId == 'lsdyna'"
            },
            {
                "command": "extension.jumpToPreviousKeyword",
                "key": "ctrl+alt+up",
                "when": "editorLangId == 'lsdyna'"
            },
            {
                "command": "extension.lsdynaTab",
                "key": "tab",
                "when": "editorTextFocus && editorLangId == 'lsdyna' && !suggestWidgetVisible && !inSnippetMode && lsdyna.shouldAlignTab && config.lsdyna.enableTabNavigation"
            },
            {
                "command": "extension.lsdynaShiftTab",
                "key": "shift+tab",
                "when": "editorTextFocus && editorLangId == 'lsdyna' && !suggestWidgetVisible && !inSnippetMode && lsdyna.shouldAlignTab && config.lsdyna.enableTabNavigation"
            },
            {
                "command": "extension.lsdynaSelectCell",
                "key": "shift+alt+right",
                "when": "editorTextFocus && editorLangId == 'lsdyna' && lsdyna.shouldAlignTab && config.lsdyna.enableTabNavigation"
            }
        ],
        "configurationDefaults": {
            "[lsdyna]": {
                "editor.wordBasedSuggestions": "off",
                "editor.wordSeparators": "`~!@#$%^&*()=+[{]}\\|;:'\",<>/?",
                "editor.wordWrap": "off",
                "editor.guides.indentation": false,
                "editor.renderIndentGuides": false,
                "editor.renderWhitespace": "all",
                "editor.insertSpaces": true,
                "editor.detectIndentation": false,
                "editor.rulers": [
                    { "column": 10, "color": "rgba(128, 128, 128, 0.15)" },
                    { "column": 20, "color": "rgba(128, 128, 128, 0.15)" },
                    { "column": 30, "color": "rgba(128, 128, 128, 0.15)" },
                    { "column": 40, "color": "rgba(128, 128, 128, 0.15)" },
                    { "column": 50, "color": "rgba(128, 128, 128, 0.15)" },
                    { "column": 60, "color": "rgba(128, 128, 128, 0.15)" },
                    { "column": 70, "color": "rgba(128, 128, 128, 0.15)" },
                    {
                        "column": 80,
                        "color": "#8a5cf5"
                    }
                ]
            }
        },
        "configuration": {
            "title": "LS-DYNA",
            "properties": {
                "lsdyna.manualsDir": {
                    "type": "string",
                    "default": "lsdyna_manual_pack",
                    "description": "%config.manualsDir.description%"
                },
                "lsdyna.enableTabNavigation": {
                    "type": "boolean",
                    "default": true,
                    "description": "%config.enableTabNavigation.description%"
                },
                "lsdyna.autoFormat": {
                    "type": "string",
                    "enum": [
                        "onBlur",
                        "disabled"
                    ],
                    "default": "onBlur",
                    "enumDescriptions": [
                        "%config.autoFormat.enumDescriptions.onBlur%",
                        "%config.autoFormat.enumDescriptions.disabled%"
                    ],
                    "description": "%config.autoFormat.description%"
                },
                "lsdyna.language": {
                    "type": "string",
                    "enum": [
                        "zh-cn",
                        "en"
                    ],
                    "default": "zh-cn",
                    "enumDescriptions": [
                        "%config.language.enumDescriptions.zh-cn%",
                        "%config.language.enumDescriptions.en%"
                    ],
                    "description": "%config.language.description%"
                },
                "lsdyna.additionalExtensions": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [
                        ".k",
                        ".key",
                        ".dyna",
                        ".asc"
                    ],
                    "description": "%config.additionalExtensions.description%"
                },
                "lsdyna.scanner.fullScanLargeFiles": {
                    "type": "boolean",
                    "default": false,
                    "markdownDescription": "%config.scanner.fullScanLargeFiles.markdownDescription%"
                },
                "lsdyna.ignoreFormattingKeywords": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [],
                    "description": "%config.ignoreFormattingKeywords.description%"
                },
                "lsdyna.customValidKeywords": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [
                        "*END"
                    ],
                    "description": "%config.customValidKeywords.description%"
                }
            }
        },
        "menus": {
            "view/title": [
                {
                    "command": "extension.scanIncludeTree",
                    "when": "view == lsdynaIncludeTree",
                    "group": "navigation"
                },
                {
                    "command": "extension.scanKeywordIndex",
                    "when": "view == lsdynaKeywordIndex && lsdyna.keywordIndexMode == 'local'",
                    "group": "navigation"
                },
                {
                    "command": "extension.keywordIndexSetLocal",
                    "when": "view == lsdynaKeywordIndex && lsdyna.keywordIndexMode == 'recursive'",
                    "group": "navigation"
                }
            ],
            "editor/context": [
                {
                    "command": "extension.lsdynaFormatSelection",
                    "when": "editorLangId == 'lsdyna'",
                    "group": "1_modification"
                },
                {
                    "command": "extension.openIncludeFile",
                    "when": "editorLangId == 'lsdyna' && lsdyna.onIncludeLine",
                    "group": "navigation"
                },
                {
                    "command": "extension.selectKeyword",
                    "when": "editorLangId == 'lsdyna'",
                    "group": "9_cutcopypaste"
                }
            ],
            "editor/title": [
                {
                    "command": "extension.jumpToNextKeyword",
                    "when": "editorLangId == 'lsdyna'",
                    "group": "navigation"
                },
                {
                    "command": "extension.jumpToPreviousKeyword",
                    "when": "editorLangId == 'lsdyna'",
                    "group": "navigation"
                }
            ],
            "view/item/context": [
                {
                    "command": "extension.openToSide",
                    "when": "view == lsdynaIncludeTree && viewItem == file || view == lsdynaKeywordIndex && viewItem == file",
                    "group": "inline"
                },
                {
                    "command": "extension.revealInExplorer",
                    "when": "view == lsdynaIncludeTree && viewItem == file || view == lsdynaKeywordIndex && viewItem == file",
                    "group": "inline"
                }
            ]
        }
    },
    "release": {
        "branches": "master",
        "verifyConditions": [
            "@semantic-release/github"
        ],
        "publish": [
            "@semantic-release/github"
        ],
        "success": [
            "@semantic-release/github"
        ],
        "fail": [
            "@semantic-release/github"
        ]
    },
    "dependencies": {
        "vscode-languageclient": "^7.0.0",
        "vscode-languageserver": "^7.0.0"
    }
}
